@model EmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<h1 class="h3 mb-3 text-danger">Delete Employee</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this employee? This action cannot be undone.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Department?.Name</dd>

            <dt class="col-sm-3">Job Title</dt>
            <dd class="col-sm-9">@Model.JobTitle</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
