@model IEnumerable<EmployeeManagement.Models.Employee>
@{
    ViewData["Title"] = "Employees";
    var search = ViewData["Search"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Employees</h1>
    <a asp-action="Create" class="btn btn-success">+ Add Employee</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-sm-8 col-md-6">
        <input type="text" name="search" value="@search" class="form-control"
               placeholder="Search by name or department..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Department</th>
                <th>Job Title</th>
                <th>Hire Date</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">No employees found.</td>
                </tr>
            }
            else
            {
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.Id</td>
                        <td>@emp.FullName</td>
                        <td>@emp.Email</td>
                        <td>@emp.MobileNumber</td>
                        <td>@emp.Department?.Name</td>
                        <td>@emp.JobTitle</td>
                        <td>@emp.HireDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (emp.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-info">View</a>
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<p class="text-muted">Total: @Model.Count() employee(s)</p>
